{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "apps/web/dist",
  "framework": "astro",
  "installCommand": "npm install",
  "redirects": [
    { "source": "/tools/:path*", "destination": "/", "statusCode": 302 },
    { "source": "/guides/:path*", "destination": "/", "statusCode": 302 },
    { "source": "/games/:path*", "destination": "/", "statusCode": 302 },
    { "source": "/use-cases/:path*", "destination": "/", "statusCode": 302 },
    { "source": "/compare/:path*", "destination": "/", "statusCode": 302 },
    { "source": "/for/:path*", "destination": "/", "statusCode": 302 },
    { "source": "/docs/:path*", "destination": "/", "statusCode": 302 },
    { "source": "/blog/:path*", "destination": "/", "statusCode": 302 },
    { "source": "/favorites", "destination": "/", "statusCode": 302 },
    { "source": "/ai-spaces", "destination": "/", "statusCode": 302 },
    { "source": "/contact", "destination": "/", "statusCode": 302 },
    { "source": "/login", "destination": "/", "statusCode": 302 },
    { "source": "/admin/:path*", "destination": "/", "statusCode": 302 },
    { "source": "/hub/:path*", "destination": "/", "statusCode": 302 },
    { "source": "/pdf-tools", "destination": "/", "statusCode": 302 },
    { "source": "/image-tools", "destination": "/", "statusCode": 302 },
    { "source": "/video-tools", "destination": "/", "statusCode": 302 },
    { "source": "/audio-tools", "destination": "/", "statusCode": 302 },
    { "source": "/ai-tools", "destination": "/", "statusCode": 302 },
    { "source": "/status", "destination": "/", "statusCode": 302 },
    { "source": "/accessibility", "destination": "/", "statusCode": 302 },
    { "source": "/sitemap:path*", "destination": "/", "statusCode": 302 }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), interest-cohort=()" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self'; connect-src 'self'; worker-src 'self' blob:; frame-ancestors 'none';" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains; preload" },
        { "key": "X-DNS-Prefetch-Control", "value": "on" },
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        { "key": "Cross-Origin-Resource-Policy", "value": "same-origin" }
      ]
    },
    {
      "source": "/_astro/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
