---
/**
 * Performance Optimizations Component
 * Adds resource hints, preloads, and other performance enhancements
 */

interface Props {
  toolCategory?: 'document' | 'media' | 'ai' | 'utility' | 'games';
  heavyLibs?: string[]; // List of heavy libraries that will be used
}

const { toolCategory, heavyLibs = [] } = Astro.props;

// Resource hints based on tool category
const getResourceHints = () => {
  const hints = [];

  // Preconnect to essential third-party domains
  hints.push(
    { rel: 'preconnect', href: 'https://fonts.googleapis.com' },
    { rel: 'preconnect', href: 'https://fonts.gstatic.com', crossorigin: true },
    { rel: 'preconnect', href: 'https://unpkg.com' },
    { rel: 'dns-prefetch', href: 'https://plausible.io' },
    { rel: 'dns-prefetch', href: 'https://www.googletagmanager.com' }
  );

  // Preload critical fonts
  hints.push({
    rel: 'preload',
    href: 'https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&display=swap',
    as: 'style'
  });

  // Category-specific preloads
  if (toolCategory === 'media' || heavyLibs.includes('ffmpeg')) {
    hints.push({
      rel: 'prefetch',
      href: 'https://unpkg.com/@ffmpeg/core@0.12.6/dist/esm/ffmpeg-core.js',
      as: 'script'
    });
  }

  return hints;
};

const resourceHints = getResourceHints();
---

<!-- Resource Hints -->
{resourceHints.map(hint => (
  <link rel={hint.rel} href={hint.href} {...(hint.crossorigin && { crossorigin: '' })} {...(hint.as && { as: hint.as })} />
))}

<!-- Critical CSS Inlining Hint -->
<style is:inline>
  /* Critical path CSS for initial render */
  :root {
    --bg: #0a0a0a;
    --text: #e0e0e0;
    --border: #222222;
    --accent: #00d4ff;
  }

  /* Prevent FOUC */
  html {
    background-color: var(--bg);
    color: var(--text);
  }

  /* Ensure main content is visible immediately */
  main {
    min-height: 100vh;
    opacity: 1;
  }

  /* Loading state for heavy tools */
  .loading-libs {
    position: relative;
  }

  .loading-libs::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.05), transparent);
    animation: shimmer 2s infinite;
  }

  @keyframes shimmer {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(100%); }
  }
</style>

<!-- Performance Monitoring -->
<script is:inline>
  // Web Vitals monitoring
  (function() {
    // Only run in production
    if (window.location.hostname === 'localhost') return;

    // CLS monitoring
    let clsValue = 0;
    let clsEntries = [];

    new PerformanceObserver((list) => {
      for (const entry of list.getEntries()) {
        if (!entry.hadRecentInput) {
          clsValue += entry.value;
          clsEntries.push(entry);
        }
      }
    }).observe({ entryTypes: ['layout-shift'] });

    // LCP monitoring
    let lcpValue = 0;
    new PerformanceObserver((list) => {
      const entries = list.getEntries();
      const lastEntry = entries[entries.length - 1];
      lcpValue = lastEntry.startTime;
    }).observe({ entryTypes: ['largest-contentful-paint'] });

    // FID monitoring
    new PerformanceObserver((list) => {
      for (const entry of list.getEntries()) {
        const delay = entry.processingStart - entry.startTime;
        // Send to analytics if delay > 100ms
        if (delay > 100 && window.gtag) {
          window.gtag('event', 'core_web_vitals', {
            event_category: 'Performance',
            event_label: 'FID',
            value: Math.round(delay),
            non_interaction: true
          });
        }
      }
    }).observe({ entryTypes: ['first-input'] });

    // Report Web Vitals on page unload
    window.addEventListener('beforeunload', () => {
      if (window.gtag) {
        window.gtag('event', 'core_web_vitals', {
          event_category: 'Performance',
          event_label: 'CLS',
          value: Math.round(clsValue * 1000) / 1000,
          non_interaction: true
        });

        window.gtag('event', 'core_web_vitals', {
          event_category: 'Performance',
          event_label: 'LCP',
          value: Math.round(lcpValue),
          non_interaction: true
        });
      }
    });

    // Long Task monitoring (for INP)
    if ('PerformanceObserver' in window) {
      try {
        new PerformanceObserver((list) => {
          for (const entry of list.getEntries()) {
            if (entry.duration > 50 && window.gtag) {
              window.gtag('event', 'long_task', {
                event_category: 'Performance',
                event_label: entry.name || 'unknown',
                value: Math.round(entry.duration),
                non_interaction: true
              });
            }
          }
        }).observe({ entryTypes: ['longtask'] });
      } catch (e) {
        // Long task observer not supported
      }
    }
  })();
</script>

<!-- Lazy loading polyfill for older browsers -->
<script is:inline>
  if ('loading' in HTMLImageElement.prototype) {
    document.documentElement.classList.add('native-lazy-loading');
  } else {
    // Fallback handled by browser
  }
</script>
