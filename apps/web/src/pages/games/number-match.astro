---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/ui/Navbar.astro';
import Footer from '../../components/ui/Footer.astro';
import NumberMatchGame from '../../components/games/NumberMatchGame';
import { getGameById } from '../../lib/games';

const game = getGameById('number-match');

const title = game?.seo?.title || 'Number Match - Free Number Puzzle Game | New Life Games';
const description = game?.seo?.metaDescription || 'Merge matching numbers to get higher values! A connect-2 puzzle game. Free to play, no download required.';
---

<Layout title={title} description={description} canonicalUrl="https://www.newlifesolutions.dev/games/number-match/">
  <!-- GEO 2025: AI-Specific Meta Tags for Game Content -->
  <meta name="ai-content-declaration" content="interactive-game, human-verified-rules" slot="head" />
  <meta name="interactive-content-type" content="number-puzzle-game" slot="head" />
  <meta name="game-mechanics" content="merge-puzzle, connect-2, tile-matching" slot="head" />
  <meta name="ai-roadmap" content="game-completion, leaderboard, high-score" slot="head" />
  <meta name="last-verified" content={new Date().toISOString()} slot="head" />
  <meta name="content-accuracy" content="verified-february-2026" slot="head" />

  <Navbar />
  <main class="pt-16">
    <!-- Hero Section -->
    <section class="py-12 px-6 border-b border-[var(--border)]">
      <div class="max-w-4xl mx-auto text-center">
        <a href="/games" class="text-xs text-[var(--text-muted)] uppercase tracking-wider hover:text-[var(--accent)] transition-colors mb-4 inline-block">
          ← Back to Games
        </a>
        <div class="text-4xl mb-4">🔢</div>
        <h1 class="text-2xl uppercase tracking-[0.3em] mb-4">{game?.seo?.h1 || 'Number Match'}</h1>
        <p class="text-[var(--text-dim)] text-sm max-w-xl mx-auto leading-relaxed">
          {game?.description || 'Merge matching numbers to get higher values! A connect-2 style puzzle game.'}
        </p>
      </div>
    </section>

    <!-- Game Section -->
    <section class="py-12 px-6">
      <div class="max-w-4xl mx-auto">
        <NumberMatchGame client:load />
      </div>
    </section>

    <!-- Game Info Section -->
    <section class="py-12 px-6 border-t border-[var(--border)]">
      <div class="max-w-2xl mx-auto">
        <h2 class="text-lg uppercase tracking-[0.2em] text-center mb-8">How to Play</h2>

        <div class="space-y-6 text-[var(--text-dim)]">
          <div class="flex gap-4">
            <div class="w-8 h-8 rounded-full bg-[var(--accent)] flex items-center justify-center flex-shrink-0 text-white font-bold">1</div>
            <div>
              <h3 class="text-[var(--text)] font-medium mb-1">Select Two Tiles</h3>
              <p class="text-sm">Tap any numbered tile to select it. It will highlight to show it's selected.</p>
            </div>
          </div>

          <div class="flex gap-4">
            <div class="w-8 h-8 rounded-full bg-[var(--accent)] flex items-center justify-center flex-shrink-0 text-white font-bold">2</div>
            <div>
              <h3 class="text-[var(--text)] font-medium mb-1">Match Adjacent Tiles</h3>
              <p class="text-sm">Tap an adjacent tile (horizontally or vertically) with the same number to merge them.</p>
            </div>
          </div>

          <div class="flex gap-4">
            <div class="w-8 h-8 rounded-full bg-[var(--accent)] flex items-center justify-center flex-shrink-0 text-white font-bold">3</div>
            <div>
              <h3 class="text-[var(--text)] font-medium mb-1">Create Bigger Numbers</h3>
              <p class="text-sm">Merged tiles combine into the next number (2+2=4, 4+4=8, 8+8=16...). Aim for the highest score!</p>
            </div>
          </div>

          <div class="flex gap-4">
            <div class="w-8 h-8 rounded-full bg-[var(--accent)] flex items-center justify-center flex-shrink-0 text-white font-bold">4</div>
            <div>
              <h3 class="text-[var(--text)] font-medium mb-1">Beat Your High Score</h3>
              <p class="text-sm">Your scores are saved locally. Try different board sizes to challenge yourself!</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats Section -->
    <section class="py-12 px-6 border-t border-[var(--border)] bg-[var(--bg-secondary)]">
      <div class="max-w-2xl mx-auto">
        <h2 class="text-lg uppercase tracking-[0.2em] text-center mb-8">Game Features</h2>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <div class="text-center p-4">
            <div class="text-2xl font-bold text-[var(--accent)] mb-1">3</div>
            <div class="text-xs text-[var(--text-muted)] uppercase tracking-wider">Board Sizes</div>
          </div>
          <div class="text-center p-4">
            <div class="text-2xl font-bold text-[var(--success)] mb-1">11</div>
            <div class="text-xs text-[var(--text-muted)] uppercase tracking-wider">Tile Values</div>
          </div>
          <div class="text-center p-4">
            <div class="text-2xl font-bold text-[var(--warning)] mb-1">∞</div>
            <div class="text-xs text-[var(--text-muted)] uppercase tracking-wider">Possibilities</div>
          </div>
          <div class="text-center p-4">
            <div class="text-2xl font-bold text-[var(--text)] mb-1">100%</div>
            <div class="text-xs text-[var(--text-muted)] uppercase tracking-wider">Free</div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
