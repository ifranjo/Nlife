---
/**
 * Index Page - Site offline
 * Previous redirect to /hub removed. Site is taken down.
 */
import '../styles/global.css';

const baseUrl = 'https://www.newlifesolutions.dev';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="New Life Solutions is currently offline." />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={`${baseUrl}/`} />
    <title>New Life Solutions - Offline</title>
    <style>
      :root {
        --bg: #0a0a0a;
        --text: #e0e0e0;
        --dim: #333333;
        --muted: #666666;
      }

      * { margin: 0; padding: 0; box-sizing: border-box; }

      body {
        background: var(--bg);
        color: var(--text);
        font-family: 'Courier New', monospace;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        position: relative;
      }

      .grid-bg {
        position: fixed;
        inset: 0;
        background-image:
          linear-gradient(var(--dim) 1px, transparent 1px),
          linear-gradient(90deg, var(--dim) 1px, transparent 1px);
        background-size: 50px 50px;
        opacity: 0.1;
        z-index: 0;
      }

      .container {
        position: relative;
        z-index: 10;
        text-align: center;
        padding: 2rem;
        max-width: 480px;
      }

      .symbol {
        font-size: 3rem;
        margin-bottom: 2rem;
        opacity: 0.5;
        animation: pulse 4s ease-in-out infinite;
      }

      @keyframes pulse {
        0%, 100% { opacity: 0.3; }
        50% { opacity: 0.6; }
      }

      .title {
        font-size: 1.2rem;
        letter-spacing: 0.6em;
        font-weight: 300;
        text-transform: uppercase;
        margin-bottom: 1.5rem;
      }

      .message {
        font-size: 0.75rem;
        color: var(--muted);
        letter-spacing: 0.15em;
        line-height: 1.8;
        text-transform: uppercase;
      }

      .version {
        position: fixed;
        bottom: 2rem;
        font-size: 0.625rem;
        color: var(--dim);
        letter-spacing: 0.2em;
      }
    </style>
  </head>
  <body>
    <div class="grid-bg"></div>
    <div class="container">
      <div class="symbol">◈</div>
      <h1 class="title">New Life</h1>
      <p class="message">This site is currently offline.<br />We'll be back soon.</p>
    </div>
    <div class="version">offline</div>
  </body>
</html>
