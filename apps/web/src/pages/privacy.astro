---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/ui/Navbar.astro';
import Footer from '../components/ui/Footer.astro';

const title = 'Privacy Policy - New Life Solutions';
const description = 'How New Life Solutions handles privacy, local file processing, and minimal anonymous usage analytics.';
const canonicalUrl = 'https://www.newlifesolutions.dev/privacy';
---

<Layout title={title} description={description} canonicalUrl={canonicalUrl}>
  <link rel="canonical" href={canonicalUrl} slot="head" />
  <Navbar />

  <main class="min-h-screen pt-24 pb-16">
    <div class="max-w-3xl mx-auto px-4">
      <header class="text-center mb-12">
        <div class="inline-block px-4 py-1 mb-6 text-xs uppercase tracking-widest border border-[var(--border)] rounded-full text-[var(--text-muted)]">
          Privacy
        </div>
        <h1 class="text-4xl md:text-5xl font-light mb-4">Privacy Policy</h1>
        <p class="text-[var(--text-muted)] max-w-xl mx-auto">
          Effective date: February 23, 2026
        </p>
      </header>

      <div class="space-y-10 text-sm leading-relaxed text-[var(--text-dim)]">
        <section>
          <h2 class="text-lg font-semibold text-[var(--text)] mb-4">Summary</h2>
          <p>
            Our tools process files locally in your browser. We do not upload file contents to our servers for tool execution.
            We do collect limited anonymous usage and reliability data so we can maintain the service and improve quality.
          </p>
        </section>

        <section>
          <h2 class="text-lg font-semibold text-[var(--text)] mb-4">What We Do Not Collect</h2>
          <ul class="space-y-2 list-disc list-inside">
            <li>File contents processed by browser-based tools</li>
            <li>Extracted text, generated media, or document content</li>
            <li>Account passwords or payment card data</li>
          </ul>
        </section>

        <section>
          <h2 class="text-lg font-semibold text-[var(--text)] mb-4">What We Collect</h2>
          <ul class="space-y-2 list-disc list-inside">
            <li>Page and tool usage events (for example: views, starts, downloads)</li>
            <li>Basic technical metadata (browser, coarse network/request metadata)</li>
            <li>Aggregated diagnostics for performance and error monitoring</li>
          </ul>
          <p class="mt-3">
            Usage data is collected in aggregated or pseudonymous form and is not used to reconstruct your file contents.
          </p>
        </section>

        <section>
          <h2 class="text-lg font-semibold text-[var(--text)] mb-4">Third-Party Services</h2>
          <p>
            We may use privacy-focused analytics and hosting telemetry providers to understand service usage and reliability.
            These providers process technical event data under their own terms and policies.
          </p>
        </section>

        <section>
          <h2 class="text-lg font-semibold text-[var(--text)] mb-4">Data Retention</h2>
          <p>
            We retain operational analytics only as long as needed for security, abuse prevention, performance analysis, and service improvement.
          </p>
        </section>

        <section>
          <h2 class="text-lg font-semibold text-[var(--text)] mb-4">Contact</h2>
          <p>
            Privacy questions can be sent to
            <a href="mailto:privacy@newlifesolutions.dev" class="text-indigo-400 underline hover:text-indigo-300">
              privacy@newlifesolutions.dev
            </a>.
          </p>
        </section>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
